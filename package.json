{
  "name": "@rajparekh/roundabout",
  "version": "0.1.1",
  "description": "Local OpenAI-compatible LLM proxy",
  "main": "dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "bin": {
    "roundabout": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run tests",
    "prepack": "npm run test && npm run build",
    "release": "npm pack"
  },
  "keywords": [
    "llm",
    "proxy",
    "openai",
    "anthropic",
    "openrouter"
  ],
  "author": "Raj Parekh",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajparekh07/roundabout.git"
  },
  "bugs": {
    "url": "https://github.com/rajparekh07/roundabout/issues"
  },
  "homepage": "https://github.com/rajparekh07/roundabout#readme",
  "dependencies": {
    "@fastify/sse": "^0.4.0",
    "@inquirer/prompts": "^8.0.1",
    "commander": "^14.0.1",
    "fastify": "^5.6.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
